# PRM OCR Service — required environment variables.
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In production (Cloud Run), inject these via Secret Manager / `gcloud run
# deploy --set-secrets=...` instead of a .env file.

# ──────────────────────────────────────────────────────────────────────────
# OCR provider selection. Default: anthropic.
# Other supported values (TODO): tesseract, google_vision.
# ──────────────────────────────────────────────────────────────────────────
OCR_PROVIDER=anthropic

# ──────────────────────────────────────────────────────────────────────────
# Anthropic Claude vision (when OCR_PROVIDER=anthropic).
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
