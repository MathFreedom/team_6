# Energy Contract Optimization Service — required environment variables.
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In production (Cloud Run), inject these via Secret Manager / `gcloud run
# deploy --set-secrets=...` instead of a .env file.

# ──────────────────────────────────────────────────────────────────────────
# Linky consumption gateway (https://conso.boris.sh)
#
# Personal Bearer token obtained after authorizing the gateway on the user's
# Enedis Data Connect account. Currently single-tenant: one token = one
# user's PRMs. For multi-tenancy, replace with a per-user OAuth flow that
# stores tokens in a secret store keyed by user id.
# ──────────────────────────────────────────────────────────────────────────
CONSO_BORIS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Optional: default PRM used by smoke tests / development scripts.
# Not consumed by the production endpoint — mobile clients pass the PRM
# in the request body.
# ──────────────────────────────────────────────────────────────────────────
DEFAULT_PRM=

# ──────────────────────────────────────────────────────────────────────────
# LLM provider key for the CrewAI advisor agent that synthesizes the final
# recommendation narrative. If unset, the service falls back to a
# deterministic templated narrative (no LLM call).
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
